# Ключ Google Gemini API (AI Studio: https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_api_key_here

# Модель генерации изображений (по умолчанию — gemini-3.1-flash-image)
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image

# Пароль доступа ко всему сайту (site-wide gate)
SITE_PASSWORD=your_password_here
